SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TRADING_BOT_TOKEN=
TELEGRAM_TRADING_CHAT_ID=
CRON_SECRET=
# Secret echoed by Telegram in the x-telegram-bot-api-secret-token header.
# Register it via setWebhook (secret_token=...). If unset, the webhook auth
# guard is DISABLED (allows requests) so local dev isn't bricked — always set
# it in deployed environments.
TELEGRAM_WEBHOOK_SECRET=
# Telegram user id allowed to receive + act on AUTO-scanner proposals. The
# scanner cron (/api/cron/scan) binds every minted button nonce to this id, so
# only this user's taps can approve/skip/snooze an auto-sent card.
SCAN_OWNER_TELEGRAM_ID=
